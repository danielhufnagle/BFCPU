# Ignore every file by default.
*

# Keep walking directories so allow rules below can match nested files.
!*/

# Keep gitignore files trackable.
!.gitignore

# Allow documentation.
!*.md

# Allow RTL sources.
!*.v
!*.sv

# Allow makefiles.
!Makefile
!makefile
!*.mk

# Keep generated/local tool directories ignored even if they contain .md/.v/.sv/Makefile files.
.venv/
__pycache__/
sim_build/
verilator/
runs/
tt_submission/
